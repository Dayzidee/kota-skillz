# Kota Skillz - Open Source .gitignore

# Dependencies
node_modules/
.venv/
venv/
env/
__pycache__/
*.pyc

# Books, Extracts, and Raw Data
*.pdf
*.epub
*.mobi
*.txt
scripts/*_extracted.txt
!scripts/pdf_to_text.py

# OS Generated Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Demo/Skeleton specific (if you only want to distribute patterns)
# Un-comment these if you want to exclude the skeleton app from the pattern library
# skeleton/node_modules/
# skeleton/dist/
# skeleton/.next/
